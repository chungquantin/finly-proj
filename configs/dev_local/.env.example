# ------------------------------
# GUI (apps/mobile)
# ------------------------------
# Mobile app talks to the backend API directly.
# Use your machine LAN IP for physical devices, e.g. http://192.168.x.x:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Optional override for quote/history fetches; defaults to API_URL when omitted.
EXPO_PUBLIC_MARKET_DATA_URL=http://localhost:8000

# Optional future direct agent runtime URL. The mobile app does not call this today.
EXPO_PUBLIC_AGENT_SERVER_URL=http://localhost:8001

# ------------------------------
# Agent (apps/agents)
# ------------------------------
# LLM Providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Runtime server
FINLY_AGENTS_HOST=0.0.0.0
FINLY_AGENTS_PORT=8000
FINLY_AGENT_SERVER_PORT=8001
FINLY_AGENT_SERVER_URL=http://localhost:8001

# LLM model selection
FINLY_AGENT_MODEL=openai/gpt-4.1-mini
FINLY_INTAKE_MODEL=openai/gpt-4.1-mini
FINLY_PANEL_MODEL=openai/gpt-4.1-mini
FINLY_MEMORY_MODEL=openai/gpt-4.1-mini

# Default ticker (blank = must come from intake or request)
FINLY_DEFAULT_TICKER=

# Data vendors
# Options: yfinance, alpha_vantage, financial_datasets
FINLY_VENDOR_CORE_STOCK=yfinance
FINLY_VENDOR_TECHNICAL=yfinance
FINLY_VENDOR_FUNDAMENTAL=yfinance
FINLY_VENDOR_NEWS=yfinance

# Optional data source API keys
FINANCIAL_DATASETS_API_KEY=
EXA_API_KEY=

# Debate tuning
FINLY_MAX_DEBATE_ROUNDS=1
FINLY_MAX_RISK_ROUNDS=1

# Database
FINLY_DB_PATH=
