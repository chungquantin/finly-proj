# Agent server
FINLY_AGENTS_HOST=0.0.0.0
FINLY_AGENT_SERVER_PORT=8001

# LLM Providers
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
