# LLM Providers
# Finly agents default runtime uses OpenRouter.
OPENROUTER_API_KEY=

# API server runtime
FINLY_AGENTS_HOST=0.0.0.0
FINLY_AGENTS_PORT=8000
FINLY_AGENT_MODEL=openai/gpt-4.1-mini
FINLY_DEFAULT_TICKER=FPT

# Data vendors (default: yfinance)
FINLY_VENDOR_CORE_STOCK=yfinance
FINLY_VENDOR_TECHNICAL=yfinance
FINLY_VENDOR_FUNDAMENTAL=yfinance
FINLY_VENDOR_NEWS=yfinance

# Debate tuning
FINLY_MAX_DEBATE_ROUNDS=1
FINLY_MAX_RISK_ROUNDS=1
