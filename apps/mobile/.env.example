# Mobile app talks to the backend API directly.
# Use your machine LAN IP for physical devices, e.g. http://192.168.x.x:8000
EXPO_PUBLIC_API_URL=http://localhost:8000

# Optional override for quote/history fetches; defaults to API_URL when omitted.
EXPO_PUBLIC_MARKET_DATA_URL=http://localhost:8000

# Optional future direct agent runtime URL. The mobile app does not call this today.
EXPO_PUBLIC_AGENT_SERVER_URL=http://localhost:8001
